# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (opsional, untuk operasi admin di API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration (Monetization Phase 2)
# Dapatkan di https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Price IDs — buat produk & harga di Stripe Dashboard > Product Catalog
# STRIPE_BASIC_PRICE_ID=price_1R0ABC...
# STRIPE_PRO_PRICE_ID=price_1R0DEF...

# Monitoring (Phase 2C)
# Dapatkan DSN di https://shootlink.sentry.io/settings/projects/nextjs/keys/
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.us.sentry.io/xxxxx

